// queries
db.posts.find();

db.posts.updateOne(
    { "user.username": "Naruto Uzumaki" },
    { $set: { "engagement.likes": 150 } }
);

db.posts.deleteOne(
    { "user.username": "Light Yagami" }
);


// aggregations
db.posts.aggregate([
    { $unwind: "$hashtags" },
    { $group: { _id: "$hashtags", count: { $sum: 1 } } },
    { $sort: { count: -1 } },
    { $limit: 5 }
]);

db.posts.aggregate([
    {
        $group: {
            _id: "$user.username",
            avgLikes: { $avg: "$engagement.likes" }
        }
    },
    { $sort: { avgLikes: -1 } }
]);

db.posts.aggregate([
    {
        $group: {
            _id: "$user.username",
            totalShares: { $sum: "$engagement.shares" }
        }
    },
    { $sort: { totalShares: -1 } },
    { $limit: 3 }
]);


// filters
db.posts.find({ "user.location": "Konoha" });


// indexes
db.posts.createIndex({ hashtags: 1 });
db.posts.createIndex({ "engagement.likes": 1 });
db.posts.createIndex({ "user.username": 1 });
db.posts.createIndex({ created_at: 1 });

db.posts.getIndexes();