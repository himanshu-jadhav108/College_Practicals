// queries
db.users.find();

db.users.updateOne(
    { name: "Eren Yeager" },
    { $set: { city: "Paradise Island" } }
);

db.users.deleteOne(
    { name: "Ichigo Kurosaki" }
);


db.users.aggregate([
    {
        $group: {
            _id: null,
            avgAge: { $avg: "$age" }
        }
    }
]);

db.users.aggregate([
    {
        $group: {
            _id: null,
            totalPurchase: { $sum: "$purchase_amount" }
        }
    }
]);

db.users.aggregate([
    {
        $group: {
            _id: "$city",
            avgPurchase: { $avg: "$purchase_amount" }
        }
    },
    {
        $sort: { avgPurchase: -1 }
    }
]);

db.users.aggregate([
    {
        $match: {
            age: { $gt: 25 }
        }
    },
    {
        $group: {
            _id: "$city",
            totalPurchase: { $sum: "$purchase_amount" }
        }
    }
]);


// indexes
db.users.createIndex({ age: 1 });

db.users.createIndex(
    { email: 1 },
    { unique: true }
);

db.users.getIndexes();